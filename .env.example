# Frontend environment variables.
# Copy this file to .env and fill in values as needed.
#
# VITE_AI_ENDPOINT is public build configuration, not a secret (amendment 13).
# It is the URL of your deployed Cloud Function or local emulator.
# Leave empty to run without AI features — the app works fully without it.
#
# For local emulator development:
#   VITE_AI_ENDPOINT=http://localhost:5001/your-project-id/us-central1/insights
#
# For production deployment:
#   VITE_AI_ENDPOINT=https://us-central1-your-project-id.cloudfunctions.net/insights

VITE_AI_ENDPOINT=
