# Frontend environment variables (Vite/React app).
# Copy this file to .env and fill in values as needed.
#
# ┌─────────────────────────────────────────────────────────────────────────┐
# │  SECURITY: This file is for PUBLIC build-time configuration ONLY.      │
# │  NEVER put API keys or secrets in VITE_ variables — they are bundled   │
# │  into the client JS and visible to anyone.                              │
# │  GEMINI_API_KEY belongs in server/.env (backend only).                 │
# │  There is no VITE_GEMINI_API_KEY — this is intentional by design.      │
# └─────────────────────────────────────────────────────────────────────────┘
#
# VITE_AI_ENDPOINT — URL of the AI backend.
# Leave empty to run without AI features (the app works fully without it).
#
# ── Local development with Render-style server (recommended) ──
#   Start the backend first: npm run dev:server
#   VITE_AI_ENDPOINT=http://localhost:10000/insights
#
# ── Production (Render deployment) ──
#   VITE_AI_ENDPOINT=https://your-render-service.onrender.com/insights
#
# ── Legacy: Firebase emulator (optional) ──
#   VITE_AI_ENDPOINT=http://localhost:5001/your-project-id/us-central1/insights

VITE_AI_ENDPOINT=
