# Express server — local environment.
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
#
# ┌─────────────────────────────────────────────────────────────────────┐
# │  SECURITY: GEMINI_API_KEY is a secret. Keep it out of version       │
# │  control, logs, and all client-facing code. It must never appear    │
# │  in server responses or VITE_* variables.                           │
# └─────────────────────────────────────────────────────────────────────┘
#
# Get a free key at: https://aistudio.google.com/apikey

GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model — defaults to gemini-2.5-flash-lite if omitted.
GEMINI_MODEL=gemini-2.5-flash-lite

# Comma-separated list of allowed CORS origins.
# Add your Vercel frontend URL here after deploying.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Port — Render injects PORT automatically. Set to 10000 locally.
PORT=10000
