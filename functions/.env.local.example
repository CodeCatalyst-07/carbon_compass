# Functions local environment — for Firebase Emulator development only.
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
#
# This file is an alternative to .secret.local for providing the Gemini API key
# to the emulator. Use whichever you prefer — both are gitignored.
#
# Get a free API key at: https://aistudio.google.com/apikey

GEMINI_API_KEY=your_local_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash-lite
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
