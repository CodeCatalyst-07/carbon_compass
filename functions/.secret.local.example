# Functions secrets — for Firebase Emulator local development only.
# Copy this file to .secret.local and fill in your values.
# NEVER commit .secret.local to version control.
#
# Get a free API key at: https://aistudio.google.com/apikey
#
# Alternative: you can also put this in functions/.env.local instead.
# Both files are gitignored and both are read by the emulator.

GEMINI_API_KEY=your-gemini-api-key-here
